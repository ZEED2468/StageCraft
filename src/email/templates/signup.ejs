<html>
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
        }
        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }
        .header {
            text-align: center;
            padding-bottom: 20px;
        }
        .otp {
            font-size: 24px;
            font-weight: bold;
            color: #333;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h2>Your OTP Code</h2>
        </div>
        <p>Hi <%= username %>,</p>
        <p>Use the following OTP to complete your sign-up process:</p>
        <p class="otp"><%= otp %></p>
        <p>If you did not request this, please ignore this email.</p>
        <p>Thank you!</p>
    </div>
</body>
</html>
